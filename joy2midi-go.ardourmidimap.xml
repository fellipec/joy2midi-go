<?xml version="1.0" encoding="UTF-8"?>
<!--
  Binding map pro joy2midi-go + meu-joystick.cfg.

  Como carregar:
    Edit > Preferences > Control Surfaces > Generic MIDI > double-click
    na entrada, aí seleciona este arquivo.

  Todas as ações abaixo foram confirmadas contra uma lista real de
  action-names do Ardour: não deve precisar trocar nada, mas se algo
  não disparar, `ardour -A` no terminal lista as ações da SUA versão
  instalada, pra comparar.
-->
<ArdourMIDIBindings version="1.0.0" name="joy2midi-go" manufacturer="fellipec">

  <!-- Hat0X: navegação do playhead -->
  <Binding channel="1" ctl="102" value="127" action="Editor/scroll-playhead-forward"/>
  <Binding channel="1" ctl="103" value="127" action="Editor/scroll-playhead-backward"/>

  <!-- Hat0Y: zoom -->
  <Binding channel="1" ctl="104" value="127" action="Editor/temporal-zoom-in"/>
  <Binding channel="1" ctl="105" value="127" action="Editor/temporal-zoom-out"/>

  <!-- ThumbBtn: panic (mata notas presas) -->
  <Binding channel="1" ctl="107" value="127" action="MIDI/panic"/>

  <!-- Botões da base: nomes confirmados -->
  <Binding channel="1" ctl="108" value="127" action="Transport/GotoStart"/>
  <Binding channel="1" ctl="109" value="127" action="Transport/ToggleClick"/>

</ArdourMIDIBindings>
